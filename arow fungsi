// Fungsi tradisional
const kaliDuaTradisional = function(angka) {
    return angka * 2;
};
console.log(kaliDuaTradisional(5)); // Output: 10

// Arrow Function (satu parameter, satu baris return)
const kaliDuaArrow = (angka) => angka * 2;
console.log(kaliDuaArrow(7)); // Output: 14

// Arrow Function dengan lebih dari satu parameter
const kurang = (a, b) => a - b;
console.log(kurang(10, 4)); // Output: 6

// Arrow Function dengan banyak baris kode (perlu kurung kurawal)
const cetakPesan = (nama, usia) => {
    const pesan = `Nama saya ${nama} dan usia saya ${usia} tahun.`;
    console.log(pesan);
};
cetakPesan("Rizky", 25); // Output: Nama saya Rizky dan usia saya 25 tahun.